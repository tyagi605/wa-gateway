# WhatsApp Gateway - Environment Configuration

# (REQUIRED) Strong API key for authentication
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your-super-secret-random-key-change-this-in-production

# (OPTIONAL) Webhook URL to receive incoming messages
# Example: https://your-domain.com/webhook
WEBHOOK_URL=

# (OPTIONAL) Port to run the gateway on (default: 3000)
PORT=3000

# (OPTIONAL) Node environment
NODE_ENV=development
